# ═══════════════════════════════════════════════════════════
#  Warhex Arena Pro — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── Server ───
PORT=3000
NODE_ENV=production
CLIENT_ORIGIN=*

# ─── Database (PostgreSQL) ───
# For Railway: railway variables provide DATABASE_URL automatically
# For Neon:    postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# For Render:  provided in dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/warhex

# ─── Auth ───
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-hex-secret-key-generated-above
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── TURN Server (Metered.ca Open Relay) ───
# Free tier: 20GB/month — https://www.metered.ca/tools/openrelay/
# Static auth mode (no signup required):
TURN_HOST=staticauth.openrelay.metered.ca
TURN_PORT=80
TURN_PORT_TLS=443
TURN_SECRET=openrelayprojectsecret
# If you have a Metered API key instead, set this:
METERED_API_KEY=
METERED_APP_NAME=

# ─── STUN ───
STUN_URL=stun:stun.l.google.com:19302

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ───
LOG_LEVEL=info
